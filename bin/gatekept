.card{background:linear-gradient(180deg,var(--panel),var(--panel2));border:1px solid var(--line);border-radius:13px;padding:16px}
.k{color:var(--mut);font-size:11px;text-transform:uppercase;letter-spacing:.07em}
.v{font-size:26px;font-weight:700;margin-top:6px}.v.grn{color:var(--grn)}.v.red{color:var(--red)}.v small{font-size:13px;color:var(--mut);font-weight:500}
.posture{display:flex;align-items:center;gap:13px}
