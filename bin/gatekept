#!/usr/bin/env bash
# gatekept — macOS security audit & optimization
# https://github.com/myusufyilmaz/gatekept   (MIT)
#
# Catches fake / cracked / tampered apps that signature antivirus misses,
# audits hardening posture & persistence, reclaims dev caches, and can render
# a self-contained HTML dashboard.
#
#   gatekept audit              read-only security audit (default)
#   gatekept report             generate + open an HTML dashboard
#   gatekept optimize [--apply] reclaim dev caches (dry-run unless --apply)
#   gatekept scan               ClamAV known-malware scan (if installed)
#   gatekept full               audit + optimize (dry-run)
#   gatekept --help | --version
#
# Read-only by design. Nothing is deleted without --apply, and even then only
# regenerable caches. Never touches user data or the cloud-storage mount.

set -uo pipefail
VERSION="1.1.0"

# ---- presentation (TTY-aware) ----------------------------------------------
if [ -t 1 ]; then
  B=$'\033[1m'; DIM=$'\033[2m'; R=$'\033[31m'; G=$'\033[32m'; C=$'\033[36m'; X=$'\033[0m'
else
  B=""; DIM=""; R=""; G=""; C=""; X=""
fi
bold()  { printf "%s%s%s\n" "$B" "$1" "$X"; }
hr()    { printf "%s" "$DIM"; printf -- '─%.0s' $(seq 1 70); printf "%s\n" "$X"; }
flag()  { printf "  %s⚠ %s%s\n" "$R" "$1" "$X"; }
ok()    { printf "  %s✓ %s%s\n" "$G" "$1" "$X"; }
info()  { printf "  %s\n" "$1"; }

banner() {
  printf "%s" "$C"
  cat <<'EOF'
   ____       _       _              _
  / ___| __ _| |_ ___| | _____ _ __ | |_
 | |  _ / _` | __/ _ \ |/ / _ \ '_ \| __|
 | |_| | (_| | ||  __/   <  __/ |_) | |_
  \____|\__,_|\__\___|_|\_\___| .__/ \__|
                              |_|
EOF
  printf "%s" "$X"
  printf "  %smacOS security audit & optimization  v%s%s\n\n" "$DIM" "$VERSION" "$X"
}

usage() {
  banner
  cat <<EOF
Usage: gatekept <command> [options]

Commands:
  audit              Read-only security audit (posture, fake-app sweep,
                     persistence, resources). Default if no command given.
  report             Render a self-contained HTML dashboard and open it.
  optimize           Report reclaimable dev caches + memory pressure.
    --apply          Actually clean caches (npm/pnpm/pip/brew) + unused sims.
  scan               ClamAV known-malware scan (requires: brew install clamav).
  full               audit, then optimize (dry-run).

Options:
  -h, --help         Show this help.
  -v, --version      Show version.

Safety:
  • audit/report/scan are read-only. optimize is dry-run unless --apply.
  • The iCloud / Google Drive CloudStorage mount is always excluded.
  • Remove flagged apps to Trash (reversible), never with rm. Confirm first.
EOF
}

CLOUD_EXCLUDE="^${HOME}/Library/CloudStorage"
require_macos() { [ "$(uname -s)" = "Darwin" ] || { echo "gatekept: macOS only." >&2; exit 2; }; }

# ---- posture helpers -------------------------------------------------------
p_sip()       { csrutil status 2>/dev/null | sed 's/.*status: //;s/\.$//' ; }
p_gatekeeper(){ spctl --status 2>/dev/null | sed 's/assessments //' ; }
p_firewall()  { /usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null | sed 's/.*Firewall is //;s/\. .*//' ; }
p_filevault() { fdesetup status 2>/dev/null | sed 's/FileVault is //;s/\.$//' ; }
p_xprotect()  { defaults read /Library/Apple/System/Library/CoreServices/XProtect.bundle/Contents/Info.plist CFBundleShortVersionString 2>/dev/null || echo unknown ; }

# ---- core: scan every app, emit TSV records --------------------------------
# record: STATUS \t NAME \t SIGNER \t NOTARIZED \t RUNTIME \t REASON
scan_apps() {
  local app name csinfo spinfo auth inj reason notar rt gk_ok status
  while IFS= read -r app; do
    [ -z "$app" ] && continue
    name=$(basename "$app" .app)
    csinfo=$(codesign -dvvv "$app" 2>&1)
    spinfo=$(spctl -a -t exec -vv "$app" 2>&1)
    auth=$(printf '%s\n' "$csinfo" | sed -n 's/^Authority=//p' | head -1)
    inj=$(find "$app/Contents/MacOS" -maxdepth 1 -iname '*inject*' 2>/dev/null | head -1)
    gk_ok=true;   printf '%s\n' "$spinfo" | grep -qi 'accepted' || gk_ok=false
    notar=no;     printf '%s\n' "$spinfo" | grep -qi 'Notarized' && notar=yes
    rt=no;        printf '%s\n' "$csinfo" | grep -q 'flags=.*runtime' && rt=yes

    reason=""
    [ -n "$inj" ] && reason="injector dylib ($(basename "$inj")); ${reason}"
    printf '%s\n' "$csinfo" | grep -q 'flags=.*adhoc' && reason="ad-hoc signed; ${reason}"
    case "$auth" in
      "Apple Development"*|"Apple Distribution"*) reason="dev/sideloaded cert; ${reason}" ;;
      "Developer ID Application"*|"Apple iPhone OS Application Signing"|"Software Signing"|"Apple Mac OS Application Signing"|"Apple Mac OS X Application Signing") : ;;
      *) [ "$gk_ok" = false ] && reason="unrecognized signer + Gatekeeper-rejected; ${reason}" ;;
    esac

    status="OK"; [ -n "$reason" ] && status="FLAG"
    [ -z "$reason" ] && reason="-"
    [ -z "$auth" ] && auth="(unsigned)"
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$status" "$name" "$auth" "$notar" "$rt" "${reason%; }"
  done < <(find /Applications -maxdepth 2 -name "*.app" -prune 2>/dev/null)
}

# ---- command: audit (text) -------------------------------------------------
cmd_audit() {
  bold "==== gatekept :: security audit ===="
  echo "host: $(scutil --get ComputerName 2>/dev/null || hostname)   $(sw_vers -productName) $(sw_vers -productVersion)   $(date '+%Y-%m-%d %H:%M')"
  hr
  bold "1. Hardening posture"
  info "SIP:        $(p_sip)"
  info "Gatekeeper: $(p_gatekeeper)"
  info "Firewall:   $(p_firewall)"
  info "FileVault:  $(p_filevault)"
  info "XProtect:   $(p_xprotect)"
  hr
  bold "2. App signature sweep — flags fake / cracked / tampered apps"
  local recs total=0 okc=0 flagc=0 notarc=0 rtc=0
  recs=$(scan_apps)
  while IFS=$'\t' read -r st nm sg no rt rsn; do
    [ -z "$st" ] && continue
    total=$((total+1))
    [ "$no" = yes ] && notarc=$((notarc+1))
    [ "$rt" = yes ] && rtc=$((rtc+1))
    if [ "$st" = FLAG ]; then flagc=$((flagc+1)); flag "$nm — $rsn"; info "${DIM}signer: $sg${X}";
    else okc=$((okc+1)); fi
  done <<< "$recs"
  [ "$flagc" -eq 0 ] && ok "no suspicious app signatures found"
  hr
  bold "   summary: $total scanned · $okc verified · $flagc flagged · $notarc notarized · $rtc hardened-runtime"
  hr
  bold "3. Persistence (LaunchAgents / LaunchDaemons)"
  local d f
  for d in "$HOME/Library/LaunchAgents" /Library/LaunchAgents /Library/LaunchDaemons; do
    info "$d:"
    [ -d "$d" ] && for f in "$d"/*.plist; do [ -e "$f" ] && printf "      %s\n" "$(basename "$f")"; done
  done
  info "${DIM}review any name that is random, non-vendor, or unfamiliar${X}"
  hr
  bold "4. Resource snapshot"
  info "Top CPU:"; ps aux | sort -nrk 3 | head -5 | awk '{printf "      %5s%%  %s\n",$3,$11}'
  info "Swap used: $(sysctl -n vm.swapusage 2>/dev/null | sed 's/.*used = //;s/  free.*//')   ${DIM}(high swap on low RAM = memory pressure)${X}"
  hr
  if command -v clamscan >/dev/null 2>&1; then ok "ClamAV present — run: gatekept scan"
  else info "ClamAV not installed (optional): brew install clamav && freshclam"; fi
  hr
  bold "audit complete. ⚠ lines = review. Nothing was changed."
}

# ---- command: report (HTML dashboard) --------------------------------------
html_escape() { sed 's/&/\&amp;/g;s/</\&lt;/g;s/>/\&gt;/g'; }

cmd_report() {
  local out="${1:-${TMPDIR:-/tmp}/gatekept-report.html}"
  bold "Scanning for HTML report... (~1-2 min)"
  local recs; recs=$(scan_apps)
  local total=0 okc=0 flagc=0 notarc=0 rtc=0 frows="" orows="" tiles="" tilen=0 st nm sg no rt rsn
  while IFS=$'\t' read -r st nm sg no rt rsn; do
    [ -z "$st" ] && continue
    total=$((total+1))
    [ "$no" = yes ] && notarc=$((notarc+1))
    [ "$rt" = yes ] && rtc=$((rtc+1))
    local cls badge verd enm row letter
    if [ "$st" = FLAG ]; then flagc=$((flagc+1)); cls="flag"; badge="Flagged"; verd="$rsn"
    else okc=$((okc+1)); cls="ok"; badge="Valid"; verd="$sg"; fi
    enm=$(printf '%s' "$nm" | html_escape); verd=$(printf '%s' "$verd" | html_escape)
    row="<tr class=\"${cls}\"><td class=\"nm\">${enm}</td><td class=\"vd\">${verd}</td><td class=\"bd\"><span class=\"badge ${cls}\">${badge}</span></td></tr>"
    if [ "$cls" = flag ]; then frows="${frows}${row}"; else orows="${orows}${row}"; fi
    if [ "$tilen" -lt 16 ]; then
      letter=$(printf '%s' "${nm:0:1}" | html_escape)
      tiles="${tiles}<div class=\"tile ${cls}\" title=\"${enm}\"><span class=\"ti\">${letter}</span><span class=\"dot\"></span></div>"
      tilen=$((tilen+1))
    fi
  done <<< "$recs"
  local rows="${frows}${orows}"
  local pct_ok=0 pct_flag=0
  [ "$total" -gt 0 ] && pct_ok=$(( okc * 100 / total )) && pct_flag=$(( flagc * 100 / total ))
  local posture="Secure" pcls="ok"; [ "$flagc" -gt 0 ] && { posture="Review needed"; pcls="warn"; }
  local flagcls=""; [ "$flagc" -gt 0 ] && flagcls="red"

  local cache_rows="" c szc disp
  for c in "$HOME/.npm" "$HOME/Library/pnpm" "$HOME/Library/Caches/pip" "$HOME/Library/Caches/Homebrew" "$HOME/.cache" "$HOME/Library/Developer/Xcode/DerivedData"; do
    [ -e "$c" ] || continue
    szc=$(du -sh "$c" 2>/dev/null | cut -f1)
    disp=$(printf '%s' "${c/#$HOME/~}" | html_escape)
    cache_rows="${cache_rows}<tr><td>${disp}</td><td class=\"r\">${szc}</td></tr>"
  done
  local ram swap host osv when
  ram=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0f GB",$1/1073741824}')
  swap=$(sysctl -n vm.swapusage 2>/dev/null | sed 's/total = //;s/  (.*//')
  host=$(scutil --get ComputerName 2>/dev/null || hostname); host=$(printf '%s' "$host" | html_escape)
  osv="$(sw_vers -productName) $(sw_vers -productVersion)"
  when=$(date '+%Y-%m-%d %H:%M')

  cat > "$out" <<HTMLEOF
<!doctype html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>gatekept — security report</title>
<style>
:root{--bg:#05080a;--win:#0b1113;--panel:#101719;--panel2:#0c1315;--line:#1b2528;--txt:#e3edee;--mut:#7f8f92;--grn:#34e0a1;--grn2:#1f6f57;--red:#ff5d6c;--amb:#ffb454}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;background:radial-gradient(1100px 520px at 82% -8%,#0c1c19,transparent),radial-gradient(800px 400px at 0% 110%,#0a1614,transparent),var(--bg);color:var(--txt);font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;padding:26px}
.win{max-width:1180px;margin:0 auto;background:linear-gradient(180deg,#0c1416,var(--win));border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.5)}
.bar{display:flex;align-items:center;gap:8px;padding:13px 16px;border-bottom:1px solid var(--line);background:#0a1012}
.dotmac{width:12px;height:12px;border-radius:50%}.dr{background:#ff5f57}.dy{background:#febc2e}.dg{background:#28c840}
.cmd{margin-left:14px;color:var(--mut);font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px}.cmd b{color:var(--grn)}
.body{display:grid;grid-template-columns:200px 1fr}
.side{border-right:1px solid var(--line);padding:16px 10px;background:#0a1113}
.brand{font-weight:800;font-size:20px;letter-spacing:-.5px;padding:6px 10px 16px;background:linear-gradient(90deg,#fff 35%,var(--grn));-webkit-background-clip:text;background-clip:text;color:transparent}
.nav a{display:flex;gap:10px;align-items:center;padding:9px 12px;border-radius:9px;color:var(--mut);text-decoration:none;font-size:13px;margin:2px 0}
.nav a.on{background:rgba(52,224,161,.12);color:var(--grn)}
.main{padding:22px}
