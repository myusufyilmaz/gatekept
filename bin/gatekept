#!/usr/bin/env bash
# gatekept — macOS security audit & optimization
# https://github.com/myusufyilmaz/gatekept   (MIT)
#
# Catches fake / cracked / tampered apps that signature antivirus misses,
# audits hardening posture, persistence (LaunchAgents/Daemons + shell configs),
# reclaims dev caches, and renders a self-contained HTML dashboard.
#
#   gatekept audit [--json]     read-only security audit (default)
#   gatekept report             generate + open an HTML dashboard
#   gatekept optimize [--apply] reclaim dev caches (dry-run unless --apply)
#   gatekept scan               ClamAV known-malware scan (if installed)
#   gatekept full               audit + optimize (dry-run)
#   gatekept --help | --version
#
# Read-only by design. Nothing is deleted without --apply, and even then only
# regenerable caches. Never touches user data or the cloud-storage mount.
# Exit status: 0 = clean, 3 = suspicious findings, 2 = usage error.

set -uo pipefail
VERSION="1.6.0"
JOBS="$(sysctl -n hw.ncpu 2>/dev/null || echo 4)"

# ---- presentation (TTY-aware; honors NO_COLOR) -----------------------------
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  B=$'\033[1m'; DIM=$'\033[2m'; R=$'\033[31m'; G=$'\033[32m'; C=$'\033[36m'; X=$'\033[0m'
else
  B=""; DIM=""; R=""; G=""; C=""; X=""
fi
bold()  { printf "%s%s%s\n" "$B" "$1" "$X"; }
hr()    { printf "%s" "$DIM"; printf -- '─%.0s' $(seq 1 70); printf "%s\n" "$X"; }
flag()  { printf "  %s⚠ %s%s\n" "$R" "$1" "$X"; }
ok()    { printf "  %s✓ %s%s\n" "$G" "$1" "$X"; }
info()  { printf "  %s\n" "$1"; }

banner() {
  printf "%s" "$C"
  cat <<'EOF'
   ____       _       _              _
  / ___| __ _| |_ ___| | _____ _ __ | |_
 | |  _ / _` | __/ _ \ |/ / _ \ '_ \| __|
 | |_| | (_| | ||  __/   <  __/ |_) | |_
  \____|\__,_|\__\___|_|\_\___| .__/ \__|
                              |_|
EOF
  printf "%s" "$X"
  printf "  %smacOS security audit & optimization  v%s%s\n\n" "$DIM" "$VERSION" "$X"
}

usage() {
  banner
  cat <<EOF
Usage: gatekept <command> [options]

Commands:
  audit [--json]     Read-only security audit (posture, fake-app sweep,
                     persistence, shell-config, resources). Default command.
  report             Render a self-contained HTML dashboard and open it.
  inspect <app>      Deep static risk analysis of one app (LOW/MED/HIGH verdict).
  optimize           Report reclaimable dev caches + memory pressure.
    --apply          Actually clean caches (npm/pnpm/pip/brew) + unused sims.
  scan               ClamAV known-malware scan (requires: brew install clamav).
  network            List listening ports and established connections.
  hosts              Check /etc/hosts and DNS servers for hijacking.
  extensions         List third-party system extensions and kexts.
  updates            Show macOS / XProtect / Homebrew patch status.
  quarantine         List quarantined downloads and where they came from.
  update-check       Check for a newer gatekept release.
  full               audit, then optimize (dry-run).

Options:
  -h, --help         Show this help.
  -v, --version      Show version.

Exit: 0 clean · 3 suspicious findings · 2 usage error.
Env:  NO_COLOR disables color · VT_API_KEY enables VirusTotal in `inspect`.

Safety:
  • audit/report/scan are read-only. optimize is dry-run unless --apply.
  • The iCloud / Google Drive CloudStorage mount is always excluded.
  • Remove flagged apps to Trash (reversible), never with rm. Confirm first.
EOF
}

CLOUD_EXCLUDE="^${HOME}/Library/CloudStorage"
require_macos() { [ "$(uname -s)" = "Darwin" ] || { echo "gatekept: macOS only." >&2; exit 2; }; }
json_escape() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

# ---- posture helpers -------------------------------------------------------
p_sip()       { csrutil status 2>/dev/null | sed 's/.*status: //;s/\.$//' ; }
p_gatekeeper(){ spctl --status 2>/dev/null | sed 's/assessments //' ; }
p_firewall()  { /usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate 2>/dev/null | sed 's/.*Firewall is //;s/\. .*//' ; }
p_filevault() { fdesetup status 2>/dev/null | sed 's/FileVault is //;s/\.$//' ; }
p_xprotect()  { defaults read /Library/Apple/System/Library/CoreServices/XProtect.bundle/Contents/Info.plist CFBundleShortVersionString 2>/dev/null || echo unknown ; }

# ---- classify one app: print TSV record ------------------------------------
# STATUS \t NAME \t SIGNER \t NOTARIZED \t RUNTIME \t REASON
classify_one() {
  local app="$1" name csinfo spinfo auth inj reason notar rt gk_ok status linker adhoc
  [ -d "$app" ] || return 0
  name=$(basename "$app" .app)
  csinfo=$(codesign -dvvv "$app" 2>&1)
  spinfo=$(spctl -a -t exec -vv "$app" 2>&1)
  auth=$(printf '%s\n' "$csinfo" | sed -n 's/^Authority=//p' | head -1)
  inj=$(find "$app/Contents/MacOS" -maxdepth 1 -iname '*inject*' 2>/dev/null | head -1)
  gk_ok=true;  printf '%s\n' "$spinfo" | grep -qi 'accepted' || gk_ok=false
  notar=no;    printf '%s\n' "$spinfo" | grep -qi 'Notarized' && notar=yes
  rt=no;       printf '%s\n' "$csinfo" | grep -q 'flags=.*runtime' && rt=yes
  linker=no; printf '%s\n' "$csinfo" | grep -q 'linker-signed' && linker=yes
  adhoc=no;  printf '%s\n' "$csinfo" | grep -q 'flags=.*adhoc' && adhoc=yes
  reason=""
  [ -n "$inj" ] && reason="injector dylib ($(basename "$inj")); ${reason}"
  # manual ad-hoc = re-signed crack/tamper. linker-signed ad-hoc = benign un-notarized
  # build (compiler-applied local signature), common for open-source / self-built apps.
  [ "$adhoc" = yes ] && [ "$linker" = no ] && reason="ad-hoc re-signed (tamper/crack pattern); ${reason}"
  case "$auth" in
    "Apple Development"*|"Apple Distribution"*) reason="dev/sideloaded cert; ${reason}" ;;
    "Developer ID Application"*|"Apple iPhone OS Application Signing"|"Software Signing"|"Apple Mac OS Application Signing"|"Apple Mac OS X Application Signing") : ;;
    *) { [ "$gk_ok" = false ] && [ "$linker" = no ]; } && reason="unrecognized signer + Gatekeeper-rejected; ${reason}" ;;
  esac
  status="OK"; [ -n "$reason" ] && status="FLAG"
  [ -z "$reason" ] && reason="-"
  [ -z "$auth" ] && auth="(unsigned)"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$status" "$name" "$auth" "$notar" "$rt" "${reason%; }"
}

# parallel sweep of every app (uses this script as the per-item worker)
scan_apps() {
  find /Applications -maxdepth 2 -name "*.app" -prune -print0 2>/dev/null \
    | xargs -0 -P "$JOBS" -I{} "$0" _classify "{}" 2>/dev/null
}

# ---- deep persistence: codesign each LaunchAgent/Daemon target -------------
# prints TSV: PLIST \t TARGET \t REASON   (only suspicious entries)
persistence_suspects() {
  local d plist prog csinfo reason
  for d in "$HOME/Library/LaunchAgents" /Library/LaunchAgents /Library/LaunchDaemons; do
    [ -d "$d" ] || continue
    for plist in "$d"/*.plist; do
      [ -e "$plist" ] || continue
      prog=$(plutil -extract Program raw -o - "$plist" 2>/dev/null)
      [ -n "$prog" ] || prog=$(plutil -extract ProgramArguments.0 raw -o - "$plist" 2>/dev/null)
      [ -n "$prog" ] || continue
      case "$prog" in /System/*) continue ;; esac     # SIP-protected Apple
      [ -e "$prog" ] || continue                       # stale plist (uninstalled app) — not a threat
      csinfo=$(codesign -dvvv "$prog" 2>&1)
      reason=""
      printf '%s\n' "$csinfo" | grep -q 'code object is not signed' && reason="unsigned binary"
      printf '%s\n' "$csinfo" | grep -q 'flags=.*adhoc' && reason="ad-hoc signed"
      case "$prog" in
        "$HOME"/*|/tmp/*|/private/tmp/*|/private/var/folders/*|/Users/Shared/*)
          printf '%s\n' "$csinfo" | grep -q 'Developer ID Application' || reason="${reason:+$reason; }runs from user-writable path" ;;
      esac
      [ -n "$reason" ] && printf '%s\t%s\t%s\n' "$(basename "$plist")" "$prog" "$reason"
    done
  done
}

# ---- shell-config hijack scan ----------------------------------------------
# prints TSV: FILE \t MATCH   (suspicious lines only)
shellrc_suspects() {
  local f
  for f in "$HOME/.zshrc" "$HOME/.zshenv" "$HOME/.zprofile" "$HOME/.bash_profile" "$HOME/.bashrc" "$HOME/.profile"; do
    [ -f "$f" ] || continue
    grep -nE '(curl|wget)[^|]*\|[[:space:]]*(sh|bash|zsh)|base64[[:space:]]+--?d|/dev/tcp/|nc[[:space:]]+-l[[:space:]]|eval[^)]*(curl|wget|http|base64)' "$f" 2>/dev/null \
      | while IFS= read -r m; do printf '%s\t%s\n' "$(basename "$f")" "$m"; done
  done
}

# ---- login items + cron + login hooks (BTM-era persistence) ----------------
# prints TSV: TYPE \t ITEM \t REASON   (suspicious only)
startup_suspects() {
  local raw name path csinfo reason h v spok
  raw=$(osascript \
    -e 'tell application "System Events"' \
    -e 'set o to {}' \
    -e 'repeat with li in login items' \
    -e 'set p to ""' \
    -e 'try' \
    -e 'set p to (path of li)' \
    -e 'end try' \
    -e 'set end of o to (name of li) & tab & p' \
    -e 'end repeat' \
    -e "set AppleScript's text item delimiters to linefeed" \
    -e 'return o as text' \
    -e 'end tell' 2>/dev/null)
  while IFS=$'\t' read -r name path; do
    [ -n "$name" ] || continue
    { [ -n "$path" ] && [ "$path" != "missing value" ] && [ -e "$path" ]; } || continue
    csinfo=$(codesign -dvvv "$path" 2>&1)
    reason=""
    printf '%s\n' "$csinfo" | grep -q 'code object is not signed' && reason="unsigned"
    printf '%s\n' "$csinfo" | grep -q 'flags=.*adhoc' && reason="ad-hoc signed"
    # location is only a flag when Gatekeeper does NOT already trust the item
    # (a notarized Developer-ID app in ~/Downloads is fine — Apple vouched for it)
    spok=true; spctl -a -t exec "$path" >/dev/null 2>&1 || spok=false
    if [ "$spok" = false ]; then
      case "$path" in
        "$HOME"/Downloads/*|/tmp/*|/private/tmp/*|/private/var/folders/*)
          reason="${reason:+$reason; }untrusted, runs from user-writable path ($path)" ;;
      esac
    fi
    [ -n "$reason" ] && printf 'login-item\t%s\t%s\n' "$name" "$reason"
  done <<< "$raw"
  for h in LoginHook LogoutHook; do
    v=$(defaults read com.apple.loginwindow "$h" 2>/dev/null) && [ -n "$v" ] \
      && printf 'login-hook\t%s\t%s\n' "$h" "$v"
  done
  if crontab -l 2>/dev/null | grep -qvE '^[[:space:]]*(#|$)'; then
    printf 'cron\tuser crontab\thas scheduled entries (legacy adware vector) — review: crontab -l\n'
  fi
}

# ---- malware staging: unsigned/ad-hoc executables in temp dirs --------------
# AMOS / ClickFix drop payloads here. prints TSV: PATH \t REASON
staging_suspects() {
  local f csinfo reason
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    csinfo=$(codesign -dvvv "$f" 2>&1)
    reason=""
    printf '%s\n' "$csinfo" | grep -q 'code object is not signed' && reason="unsigned executable in temp dir"
    printf '%s\n' "$csinfo" | grep -q 'flags=.*adhoc' && reason="ad-hoc executable in temp dir"
    [ -n "$reason" ] && printf '%s\t%s\n' "$f" "$reason"
  done < <(find /tmp /private/tmp -maxdepth 3 -type f -perm +111 2>/dev/null | grep -v '/claude-501/' | head -50)
}

# ---- downloads scan: unsigned / cracked apps freshly downloaded ------------
# AMOS & cracked apps land in ~/Downloads before they're moved to /Applications.
# prints TSV: NAME \t REASON   (flagged only)
downloads_suspects() {
  local app rec st nm rsn
  while IFS= read -r app; do
    [ -n "$app" ] || continue
    rec=$(classify_one "$app")
    IFS=$'\t' read -r st nm _ _ _ rsn <<< "$rec"
    [ "$st" = FLAG ] && printf '%s\t%s\n' "$nm" "$rsn"
  done < <(find "$HOME/Downloads" -maxdepth 2 -name "*.app" -prune 2>/dev/null)
}

# ---- command: audit --------------------------------------------------------
cmd_audit() {
  local json=false; [ "${1:-}" = "--json" ] && json=true
  local recs total=0 okc=0 flagc=0 notarc=0 rtc=0 st nm sg no rt rsn
  recs=$(scan_apps)
  while IFS=$'\t' read -r st nm sg no rt rsn; do
    [ -z "$st" ] && continue
    total=$((total+1)); [ "$no" = yes ] && notarc=$((notarc+1)); [ "$rt" = yes ] && rtc=$((rtc+1))
    [ "$st" = FLAG ] && flagc=$((flagc+1)) || okc=$((okc+1))
  done <<< "$recs"
  local persist shellh startup staging downloads pcount scount upcount stcount dcount
  persist=$(persistence_suspects); shellh=$(shellrc_suspects)
  startup=$(startup_suspects); staging=$(staging_suspects); downloads=$(downloads_suspects)
  pcount=$(printf '%s' "$persist" | grep -c . ); scount=$(printf '%s' "$shellh" | grep -c . )
  upcount=$(printf '%s' "$startup" | grep -c . ); stcount=$(printf '%s' "$staging" | grep -c . )
  dcount=$(printf '%s' "$downloads" | grep -c . )
  local findings=$((flagc + pcount + scount + upcount + stcount + dcount))

  if [ "$json" = true ]; then
    printf '{\n  "version":"%s","host":"%s","os":"%s %s",\n' \
      "$VERSION" "$(json_escape "$(scutil --get ComputerName 2>/dev/null || hostname)")" "$(sw_vers -productName)" "$(sw_vers -productVersion)"
    printf '  "posture":{"sip":"%s","gatekeeper":"%s","firewall":"%s","filevault":"%s","xprotect":"%s"},\n' \
      "$(p_sip)" "$(p_gatekeeper)" "$(p_firewall)" "$(p_filevault)" "$(p_xprotect)"
    printf '  "summary":{"scanned":%s,"verified":%s,"flagged":%s,"notarized":%s,"hardened_runtime":%s,"persistence_flags":%s,"shell_hijack_flags":%s,"login_item_flags":%s,"staging_flags":%s,"downloads_flags":%s},\n' \
      "$total" "$okc" "$flagc" "$notarc" "$rtc" "$pcount" "$scount" "$upcount" "$stcount" "$dcount"
    printf '  "flagged":['
    local first=1
    while IFS=$'\t' read -r st nm sg no rt rsn; do
      [ "$st" = FLAG ] || continue
      [ "$first" = 1 ] && first=0 || printf ','
      printf '{"app":"%s","reason":"%s"}' "$(json_escape "$nm")" "$(json_escape "$rsn")"
    done <<< "$recs"
    printf ']\n}\n'
    [ "$findings" -gt 0 ] && return 3 || return 0
  fi

  bold "==== gatekept :: security audit ===="
  echo "host: $(scutil --get ComputerName 2>/dev/null || hostname)   $(sw_vers -productName) $(sw_vers -productVersion)   $(date '+%Y-%m-%d %H:%M')"
  hr
  bold "1. Hardening posture"
  info "SIP:        $(p_sip)"; info "Gatekeeper: $(p_gatekeeper)"; info "Firewall:   $(p_firewall)"
  info "FileVault:  $(p_filevault)"; info "XProtect:   $(p_xprotect)"
  hr
  bold "2. App signature sweep — fake / cracked / tampered apps"
  while IFS=$'\t' read -r st nm sg no rt rsn; do
    [ "$st" = FLAG ] && { flag "$nm — $rsn"; info "${DIM}signer: $sg${X}"; }
  done <<< "$recs"
  [ "$flagc" -eq 0 ] && ok "no suspicious app signatures"
  info "${DIM}$total scanned · $okc verified · $flagc flagged · $notarc notarized · $rtc hardened-runtime${X}"
  hr
  bold "3. Persistence — LaunchAgents / LaunchDaemons (target binary verified)"
  if [ "$pcount" -gt 0 ]; then
    while IFS=$'\t' read -r pl tg rs; do [ -n "$pl" ] && { flag "$pl — $rs"; info "${DIM}$tg${X}"; }; done <<< "$persist"
  else ok "no suspicious persistence targets"; fi
  hr
  bold "4. Login items / cron / startup hooks (BTM-era persistence)"
  if [ "$upcount" -gt 0 ]; then
    while IFS=$'\t' read -r ty it rs; do [ -n "$ty" ] && flag "[$ty] $it — $rs"; done <<< "$startup"
  else ok "no suspicious login items, cron, or hooks"; fi
  hr
  bold "5. Shell-config hijack (.zshrc / .zshenv / .bash_profile …)"
  if [ "$scount" -gt 0 ]; then
    while IFS=$'\t' read -r fl mt; do [ -n "$fl" ] && flag "$fl: $mt"; done <<< "$shellh"
  else ok "no suspicious shell-config lines"; fi
  hr
  bold "6. Malware staging — unsigned executables in /tmp (AMOS / ClickFix drop zone)"
  if [ "$stcount" -gt 0 ]; then
    while IFS=$'\t' read -r pa rs; do [ -n "$pa" ] && { flag "$rs"; info "${DIM}$pa${X}"; }; done <<< "$staging"
  else ok "no unsigned executables staged in temp dirs"; fi
  hr
  bold "7. Downloads — unsigned / cracked apps in ~/Downloads"
  if [ "$dcount" -gt 0 ]; then
    while IFS=$'\t' read -r nm rs; do [ -n "$nm" ] && flag "$nm — $rs"; done <<< "$downloads"
  else ok "no unsigned/cracked apps in ~/Downloads"; fi
  hr
  bold "8. Resource snapshot"
  info "Top CPU:"; ps aux | sort -nrk 3 | head -5 | awk '{printf "      %5s%%  %s\n",$3,$11}'
  info "Swap used: $(sysctl -n vm.swapusage 2>/dev/null | sed 's/.*used = //;s/  free.*//')   ${DIM}(high swap on low RAM = pressure)${X}"
  hr
  if command -v clamscan >/dev/null 2>&1; then ok "ClamAV present — run: gatekept scan"
  else info "ClamAV not installed (optional): brew install clamav && freshclam"; fi
  hr
  if [ "$findings" -gt 0 ]; then bold "audit complete — ${findings} finding(s) to review."; return 3
  else bold "audit complete — clean. Nothing changed."; return 0; fi
}

# ---- command: report (HTML dashboard) --------------------------------------
html_escape() { sed 's/&/\&amp;/g;s/</\&lt;/g;s/>/\&gt;/g'; }
cmd_report() {
  local out="${1:-${TMPDIR:-/tmp}/gatekept-report.html}"
  bold "Scanning for HTML report..."
  local recs; recs=$(scan_apps)
  local total=0 okc=0 flagc=0 notarc=0 rtc=0 frows="" orows="" tiles="" tilen=0 st nm sg no rt rsn
  while IFS=$'\t' read -r st nm sg no rt rsn; do
    [ -z "$st" ] && continue
    total=$((total+1)); [ "$no" = yes ] && notarc=$((notarc+1)); [ "$rt" = yes ] && rtc=$((rtc+1))
    local cls badge verd enm row letter
    if [ "$st" = FLAG ]; then flagc=$((flagc+1)); cls="flag"; badge="Flagged"; verd="$rsn"
    else okc=$((okc+1)); cls="ok"; badge="Valid"; verd="$sg"; fi
    enm=$(printf '%s' "$nm" | html_escape); verd=$(printf '%s' "$verd" | html_escape)
    row="<tr class=\"${cls}\"><td class=\"nm\">${enm}</td><td class=\"vd\">${verd}</td><td class=\"bd\"><span class=\"badge ${cls}\">${badge}</span></td></tr>"
    if [ "$cls" = flag ]; then frows="${frows}${row}"; else orows="${orows}${row}"; fi
    if [ "$tilen" -lt 16 ]; then letter=$(printf '%s' "${nm:0:1}" | html_escape)
      tiles="${tiles}<div class=\"tile ${cls}\" title=\"${enm}\"><span class=\"ti\">${letter}</span><span class=\"dot\"></span></div>"; tilen=$((tilen+1)); fi
  done <<< "$recs"
  local rows="${frows}${orows}" pct_ok=0 pct_flag=0
  [ "$total" -gt 0 ] && pct_ok=$(( okc*100/total )) && pct_flag=$(( flagc*100/total ))
  local posture="Secure" pcls="ok" flagcls=""; [ "$flagc" -gt 0 ] && { posture="Review needed"; pcls="warn"; flagcls="red"; }
  local cache_rows="" c szc disp
  for c in "$HOME/.npm" "$HOME/Library/pnpm" "$HOME/Library/Caches/pip" "$HOME/Library/Caches/Homebrew" "$HOME/.cache" "$HOME/Library/Developer/Xcode/DerivedData"; do
    [ -e "$c" ] || continue; szc=$(du -sh "$c" 2>/dev/null | cut -f1); disp=$(printf '%s' "${c/#$HOME/~}" | html_escape)
    cache_rows="${cache_rows}<tr><td>${disp}</td><td class=\"r\">${szc}</td></tr>"
  done
  local ram swap host osv when
  ram=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0f GB",$1/1073741824}')
  swap=$(sysctl -n vm.swapusage 2>/dev/null | sed 's/total = //;s/  (.*//')
  host=$(scutil --get ComputerName 2>/dev/null || hostname); host=$(printf '%s' "$host" | html_escape)
  osv="$(sw_vers -productName) $(sw_vers -productVersion)"; when=$(date '+%Y-%m-%d %H:%M')
  cat > "$out" <<HTMLEOF
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>gatekept — security report</title><style>
:root{--bg:#05080a;--win:#0b1113;--panel:#101719;--panel2:#0c1315;--line:#1b2528;--txt:#e3edee;--mut:#7f8f92;--grn:#34e0a1;--grn2:#1f6f57;--red:#ff5d6c;--amb:#ffb454}
*{box-sizing:border-box}body{margin:0;background:radial-gradient(1100px 520px at 82% -8%,#0c1c19,transparent),var(--bg);color:var(--txt);font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;padding:26px}
.win{max-width:1180px;margin:0 auto;background:linear-gradient(180deg,#0c1416,var(--win));border:1px solid var(--line);border-radius:16px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.5)}
.bar{display:flex;align-items:center;gap:8px;padding:13px 16px;border-bottom:1px solid var(--line);background:#0a1012}
.dotmac{width:12px;height:12px;border-radius:50%}.dr{background:#ff5f57}.dy{background:#febc2e}.dg{background:#28c840}
.cmd{margin-left:14px;color:var(--mut);font-family:ui-monospace,Menlo,monospace;font-size:13px}.cmd b{color:var(--grn)}
.body{display:grid;grid-template-columns:200px 1fr}
.side{border-right:1px solid var(--line);padding:16px 10px;background:#0a1113}
.brand{font-weight:800;font-size:20px;padding:6px 10px 16px;background:linear-gradient(90deg,#fff 35%,var(--grn));-webkit-background-clip:text;background-clip:text;color:transparent}
.nav a{display:flex;gap:10px;padding:9px 12px;border-radius:9px;color:var(--mut);text-decoration:none;font-size:13px;margin:2px 0}.nav a.on{background:rgba(52,224,161,.12);color:var(--grn)}
.main{padding:22px}.sub{color:var(--mut);font-size:12px;margin:-4px 0 18px}
.row{display:grid;gap:14px}.top{grid-template-columns:1.4fr 1fr 1fr 1fr 1.3fr}
.card{background:linear-gradient(180deg,var(--panel),var(--panel2));border:1px solid var(--line);border-radius:13px;padding:16px}
.k{color:var(--mut);font-size:11px;text-transform:uppercase;letter-spacing:.07em}.v{font-size:26px;font-weight:700;margin-top:6px}.v.grn{color:var(--grn)}.v.red{color:var(--red)}.v small{font-size:13px;color:var(--mut);font-weight:500}
.posture{display:flex;align-items:center;gap:13px}.shield{width:44px;height:44px;border-radius:12px;display:grid;place-items:center;font-size:22px;background:rgba(52,224,161,.12);border:1px solid var(--grn2)}.posture.warn .shield{background:rgba(255,180,84,.12);border-color:#6b5325}.posture .v{font-size:19px;margin:0}
