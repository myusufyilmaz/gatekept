# ---- command: optimize -----------------------------------------------------
cmd_optimize() {
  local apply=false; [ "${1:-}" = "--apply" ] && apply=true
  local c; sz() { du -sh "$1" 2>/dev/null | cut -f1; }
  bold "==== gatekept :: optimize  (mode: $([ "$apply" = true ] && echo APPLY || echo DRY-RUN)) ===="
  hr; bold "Reclaimable caches (regenerate on demand):"
  for c in "$HOME/.npm" "$HOME/Library/pnpm" "$HOME/Library/Caches/pip" "$HOME/Library/Caches/Homebrew" "$HOME/Library/Caches/Yarn" "$HOME/.cache" "$HOME/Library/Caches/go-build" "$HOME/.gradle/caches" "$HOME/.cargo/registry" "$HOME/Library/Developer/Xcode/DerivedData" "$HOME/Library/Developer/CoreSimulator/Caches"; do
    [ -e "$c" ] && printf "  %-55s %s\n" "$c" "$(sz "$c")"
  done
  hr; bold "Memory pressure:"
  info "Physical RAM: $(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0f GB",$1/1073741824}')"
  info "Swap: $(sysctl -n vm.swapusage 2>/dev/null | sed 's/total = //;s/  (.*//')"
  hr
  if [ "$apply" != true ]; then bold "DRY-RUN. Re-run 'gatekept optimize --apply' to clean."; return 0; fi
  bold "Applying safe cleanups..."
  command -v npm   >/dev/null 2>&1 && { info "npm cache clean";  npm cache clean --force >/dev/null 2>&1 && ok "npm"; }
  command -v pip3  >/dev/null 2>&1 && { info "pip cache purge";  pip3 cache purge >/dev/null 2>&1 && ok "pip"; }
  command -v pnpm  >/dev/null 2>&1 && { info "pnpm store prune"; pnpm store prune >/dev/null 2>&1 && ok "pnpm"; }
  command -v brew  >/dev/null 2>&1 && { info "brew cleanup -s";  brew cleanup -s >/dev/null 2>&1 && ok "brew"; }
  command -v yarn  >/dev/null 2>&1 && { info "yarn cache clean"; yarn cache clean >/dev/null 2>&1 && ok "yarn"; }
  command -v go    >/dev/null 2>&1 && { info "go clean -cache"; go clean -cache >/dev/null 2>&1 && ok "go"; }
  command -v xcrun >/dev/null 2>&1 && { info "delete unavailable simulators"; xcrun simctl delete unavailable >/dev/null 2>&1 && ok "simulators"; }
  hr; bold "optimize complete. ~/.cache left intact (may hold slow-to-rebuild downloads)."
}

# ---- command: scan ---------------------------------------------------------
cmd_scan() {
  command -v clamscan >/dev/null 2>&1 || { echo "gatekept: ClamAV not installed. Run: brew install clamav && freshclam" >&2; return 2; }
  bold "==== gatekept :: ClamAV scan ===="
  clamscan -r -i --stdout --exclude-dir="$CLOUD_EXCLUDE" --max-filesize=200M --max-scansize=2000M \
    "$HOME/Downloads" "$HOME/Desktop" "$HOME/Documents" "/Applications" "$HOME/Library"
}

# ---- command: network — listening ports + established connections ----------
cmd_network() {
  bold "==== gatekept :: network ===="
  hr; bold "Listening ports"
  lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null | awk 'NR>1{printf "  %-22s pid %-7s %s\n",$1,$2,$9}' | sort -u | head -40
  hr; bold "Established outbound connections"
  lsof -nP -iTCP -sTCP:ESTABLISHED 2>/dev/null | awk 'NR>1{printf "  %-22s pid %-7s %s\n",$1,$2,$9}' | sort -u | head -40
  hr; info "${DIM}root-owned sockets need sudo to appear. Review unfamiliar listeners.${X}"
}

# ---- command: hosts — /etc/hosts + DNS hijack check ------------------------
cmd_hosts() {
  bold "==== gatekept :: hosts & DNS ===="
  hr; bold "Non-default /etc/hosts entries"
  local custom
  custom=$(grep -vE '^[[:space:]]*#|^[[:space:]]*$|broadcasthost|^[[:space:]]*(127\.0\.0\.1|255\.255\.255\.255|::1|0\.0\.0\.0)[[:space:]]+localhost[[:space:]]*$' /etc/hosts 2>/dev/null)
  if [ -n "$custom" ]; then
    printf '%s\n' "$custom" | while IFS= read -r l; do flag "$l"; done
    info "${DIM}custom host mappings can redirect domains (phishing/hijack) — verify each${X}"
  else ok "no custom host mappings"; fi
  hr; bold "DNS servers"
  scutil --dns 2>/dev/null | awk '/nameserver\[/{print "  "$3}' | sort -u | head
}

# ---- command: extensions — third-party system extensions & kexts ----------
cmd_extensions() {
  bold "==== gatekept :: system extensions & kexts ===="
  hr; bold "System extensions (non-Apple)"
  local sx
  sx=$(systemextensionsctl list 2>/dev/null | grep -iE '\[activated|enabled\]' | grep -vi 'com.apple')
  if [ -n "$sx" ]; then printf '%s\n' "$sx" | sed 's/^/  /'; else ok "none active"; fi
  hr; bold "Third-party kernel extensions"
  local kx
  kx=$(kmutil showloaded 2>/dev/null | grep -v 'com.apple' | grep -vE 'No variant|UUID|^[[:space:]]*$' | tail -n +1)
  if [ -n "$kx" ]; then printf '%s\n' "$kx" | sed 's/^/  /' | head -20; else ok "none (or kmutil needs sudo for full list)"; fi
}

# ---- command: updates — patch status ---------------------------------------
cmd_updates() {
  bold "==== gatekept :: updates ===="
  hr
  info "macOS:    $(sw_vers -productName) $(sw_vers -productVersion) ($(sw_vers -buildVersion))"
  info "XProtect: $(p_xprotect)"
  if command -v brew >/dev/null 2>&1; then
    info "Homebrew: $(brew outdated --quiet 2>/dev/null | grep -c .) outdated package(s)"
  fi
  hr; info "${DIM}check macOS security updates:  softwareupdate -l${X}"
}

# ---- command: quarantine — recently downloaded files + provenance ----------
cmd_quarantine() {
  bold "==== gatekept :: quarantined downloads ===="
  hr
  local f src n=0
  while IFS= read -r f; do
    [ -n "$f" ] || continue
    xattr "$f" 2>/dev/null | grep -q 'com.apple.quarantine' || continue
    src=$(mdls -name kMDItemWhereFroms "$f" 2>/dev/null | grep -vi '(null)' | tr '\n' ' ' | sed 's/kMDItemWhereFroms = //;s/[[:space:]]\{2,\}/ /g')
    printf "  %s\n" "$(basename "$f")"; [ -n "$src" ] && info "${DIM}from:$src${X}"
    n=$((n+1)); [ "$n" -ge 40 ] && break
  done < <(find "$HOME/Downloads" -maxdepth 1 -type f 2>/dev/null)
  [ "$n" -eq 0 ] && ok "no quarantined files in ~/Downloads"
  return 0
}

# ---- command: update-check — compare to latest GitHub release --------------
cmd_update_check() {
  bold "gatekept $VERSION"
  local latest
  latest=$(curl -fsSL "https://api.github.com/repos/myusufyilmaz/gatekept/releases/latest" 2>/dev/null \
    | sed -n 's/.*"tag_name":[[:space:]]*"v\{0,1\}\([^"]*\)".*/\1/p' | head -1)
  if [ -z "$latest" ]; then info "could not reach GitHub (offline?)"; return 0; fi
  if [ "$latest" = "$VERSION" ]; then ok "up to date (latest: $latest)"
  else info "latest release: $latest (you have $VERSION) — brew upgrade gatekept"; fi
}

# ---- command: inspect — deep static risk analysis of one app ---------------
# Decides whether an unsigned / un-notarized app is actually dangerous, instead
# of flagging every ad-hoc app. Verdict: LOW / MEDIUM / HIGH.
cmd_inspect() {
  local app="${1:-}"
  [ -n "$app" ] || { echo "usage: gatekept inspect /path/to/App.app" >&2; return 2; }
  [ -e "$app" ] || { echo "gatekept: not found: $app" >&2; return 2; }
  local bin csinfo spinfo auth ents iocs extlibs wherefrom e d
  local notar=no sealok=yes linker=no adhoc=no hi=0 score=0 reasons=""
  bin="$app/Contents/MacOS/$(defaults read "$app/Contents/Info.plist" CFBundleExecutable 2>/dev/null)"
  csinfo=$(codesign -dvvv "$app" 2>&1)
  spinfo=$(spctl -a -t exec -vv "$app" 2>&1)
  auth=$(printf '%s\n' "$csinfo" | sed -n 's/^Authority=//p' | head -1)
  printf '%s\n' "$spinfo" | grep -qi 'Notarized' && notar=yes
  codesign --verify --deep --strict "$app" >/dev/null 2>&1 || sealok=no
  printf '%s\n' "$csinfo" | grep -q 'linker-signed' && linker=yes
  printf '%s\n' "$csinfo" | grep -q 'flags=.*adhoc' && adhoc=yes

  bold "==== gatekept :: inspect ===="
  echo "app: $app"; hr
  bold "Signature"
  info "authority:   ${auth:-(none / ad-hoc)}"
  info "notarized:   $notar    seal: $([ "$adhoc" = yes ] && echo 'n/a (ad-hoc)' || echo "$sealok")"
  info "ad-hoc:      $adhoc    linker-signed: $linker"
  hr
  if [ "$notar" = yes ] && printf '%s' "$auth" | grep -q 'Developer ID Application'; then
    ok "Notarized Developer ID — Apple-vouched."; bold "VERDICT: LOW risk."; return 0
  fi

  bold "Indicators"
  if [ -n "$(find "$app/Contents/MacOS" -maxdepth 1 -iname '*inject*' 2>/dev/null | head -1)" ]; then
    flag "injector dylib present (crack/loader pattern)"; hi=1; reasons="injector; $reasons"; else ok "no injector dylib"; fi
  [ "$adhoc" = yes ] && [ "$linker" = no ] && { flag "manually ad-hoc re-signed (tamper pattern)"; hi=1; reasons="ad-hoc re-sign; $reasons"; }
  [ "$adhoc" = yes ] && [ "$linker" = yes ] && ok "ad-hoc but linker-signed (compiler default — benign)"
  # a broken seal only signals tampering on apps that present a REAL certificate;
  # ad-hoc / linker-signed apps legitimately have no seal, so --strict always fails.
  [ "$sealok" = no ] && [ "$adhoc" = no ] && { flag "code-signature seal broken / modified (tamper)"; hi=1; reasons="broken seal; $reasons"; }
  ents=$(codesign -d --entitlements - --xml "$app" 2>/dev/null)
  for e in get-task-allow disable-library-validation allow-dyld-environment-variables allow-unsigned-executable-memory; do
    printf '%s' "$ents" | grep -q "$e" && { flag "risky entitlement: $e"; score=$((score+1)); reasons="$e; $reasons"; }
  done
  [ "$(defaults read "$app/Contents/Info.plist" LSUIElement 2>/dev/null)" = 1 ] && \
    { info "hidden background agent (LSUIElement) — normal for menubar apps, odd for unknown tools"; score=$((score+1)); }
  if [ -e "$bin" ]; then
    extlibs=$(otool -L "$bin" 2>/dev/null | grep -E '^[[:space:]]' | sed 's/ (compatibility.*//; s/^[[:space:]]*//' | grep -vE '^/System/|^/usr/lib/|^@executable_path|^@rpath|^@loader_path')
    if [ -n "$extlibs" ]; then printf '%s\n' "$extlibs" | while read -r d; do flag "links non-system dylib: $d"; done; score=$((score+1)); reasons="non-system dylib; $reasons"; fi
    iocs=$(strings -a "$bin" 2>/dev/null | grep -iE 'osascript|/tmp/|base64[[:space:]]+-d|security[[:space:]]+find-generic-password|curl[[:space:]]|/dev/tcp/|hdiutil' | sort -u | head -8)
    [ -n "$iocs" ] && { flag "suspicious strings in binary:"; printf '%s\n' "$iocs" | sed 's/^/        /'; score=$((score+2)); reasons="IOC strings; $reasons"; }
  fi
  wherefrom=$(mdls -name kMDItemWhereFroms "$app" 2>/dev/null | grep -vi '(null)' | tr -d '\n' | sed 's/kMDItemWhereFroms = //')
  [ -n "$wherefrom" ] && info "downloaded from: $wherefrom"
  if [ -n "${VT_API_KEY:-}" ] && [ -e "$bin" ]; then
    local sha vt mal; sha=$(shasum -a 256 "$bin" | cut -d' ' -f1)
    vt=$(curl -s -H "x-apikey: ${VT_API_KEY}" "https://www.virustotal.com/api/v3/files/$sha" 2>/dev/null)
    mal=$(printf '%s' "$vt" | python3 -c "import sys,json
try: print(json.load(sys.stdin)['data']['attributes']['last_analysis_stats']['malicious'])
except Exception: print('na')" 2>/dev/null)
    case "$mal" in
      na|"") info "VirusTotal: no record / lookup failed" ;;
      0) ok "VirusTotal: 0 / many engines flag it" ;;
      *) flag "VirusTotal: $mal engines flag this binary"; hi=1; reasons="VT:$mal; $reasons" ;;
    esac
  else
    info "VirusTotal: set VT_API_KEY to enable hash-reputation lookup"
  fi
  hr
  bold "Verdict"
  if [ "$hi" -gt 0 ] || [ "$score" -ge 3 ]; then
    flag "HIGH risk — ${reasons%; }. Don't run it; move to Trash."; return 3
  elif [ "$score" -ge 1 ]; then
    flag "MEDIUM risk — ${reasons%; }. Verify the source before running."; return 3
  else
    ok "LOW risk — unsigned/un-notarized but no malicious indicators (typical of open-source or self-built apps)."; return 0
  fi
}

# ---- dispatch --------------------------------------------------------------
main() {
  case "${1:-audit}" in
    _classify)      classify_one "${2:-}" ;;          # internal parallel worker
    audit)          require_macos; shift || true; cmd_audit "${1:-}" ;;
    report|--html)  require_macos; shift || true; cmd_report "${1:-}" ;;
    inspect)        require_macos; shift || true; cmd_inspect "${1:-}" ;;
    optimize|opt)   require_macos; shift; cmd_optimize "${1:-}" ;;
    scan)           require_macos; cmd_scan ;;
    network|net)    require_macos; cmd_network ;;
    hosts|dns)      require_macos; cmd_hosts ;;
    extensions|ext) require_macos; cmd_extensions ;;
    updates)        require_macos; cmd_updates ;;
    quarantine)     require_macos; cmd_quarantine ;;
    update-check)   cmd_update_check ;;
    full)           require_macos; cmd_audit; echo; cmd_optimize ;;
    -h|--help|help) usage ;;
    -v|--version)   echo "gatekept $VERSION" ;;
    *) echo "gatekept: unknown command '$1'" >&2; echo "try: gatekept --help" >&2; exit 2 ;;
  esac
}
main "$@"
